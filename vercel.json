{
  "version": 2,
  "builds": [
    {
      "src": "api/dist/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "web/dist",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/(qr|uuid|password|hash|codec|file-hash|token)", "dest": "/api/dist/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/web/dist/$1" }
  ]
}
